{
  "name": "@ody/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": { "types": "./src/index.ts", "default": "./src/index.ts" },
    "./types": { "types": "./src/types.ts", "default": "./src/types.ts" },
    "./client": { "types": "./src/client.ts", "default": "./src/client.ts" },
    "./hooks": { "types": "./src/hooks/index.ts", "default": "./src/hooks/index.ts" },
    "./schemas": { "types": "./src/schemas/index.ts", "default": "./src/schemas/index.ts" }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "format": "biome check src --write"
  },
  "dependencies": {
    "@ody/types": "workspace:*",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/react-query": "catalog:",
    "@types/react": ">=18",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "@types/react": { "optional": true },
    "@tanstack/react-query": { "optional": true },
    "react": { "optional": true }
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@types/react": "catalog:",
    "react": "catalog:",
    "typescript": "catalog:"
  }
}
