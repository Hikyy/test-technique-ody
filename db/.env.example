# ============================================================================
# @ody/db — used by node-pg-migrate (db:migrate) and the seeder.
# ============================================================================
# Copy to db/.env

PG_HOST=localhost
PG_PORT=5435
PG_USER=ody
PG_PASS=ody
PG_DB=ody

# Optional: set DATABASE_URL to override the discrete PG_* vars.
# DATABASE_URL=postgres://ody:ody@localhost:5435/ody
