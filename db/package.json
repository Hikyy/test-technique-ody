{
  "name": "@ody/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": { "types": "./src/index.ts", "default": "./src/index.ts" },
    "./schema": { "types": "./src/schema.ts", "default": "./src/schema.ts" },
    "./client": { "types": "./src/client.ts", "default": "./src/client.ts" },
    "./seed-data": { "types": "./src/seed-data/index.ts", "default": "./src/seed-data/index.ts" }
  },
  "scripts": {
    "make": "node scripts/migrate.mjs create -j ts",
    "migrate": "node scripts/migrate.mjs up",
    "up": "node scripts/migrate.mjs up",
    "down": "node scripts/migrate.mjs down",
    "redo": "node scripts/migrate.mjs redo",
    "status": "node scripts/migrate.mjs up --dry-run",
    "seed": "node --import tsx/esm src/seed.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "node-pg-migrate": "^8.0.4",
    "pg": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  }
}
