{
  "name": "@ody/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "source": "./src/schema.ts",
      "types": "./dist/schema.d.ts",
      "default": "./dist/schema.js"
    },
    "./client": {
      "source": "./src/client.ts",
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./seed-data": {
      "source": "./src/seed-data/index.ts",
      "types": "./dist/seed-data/index.d.ts",
      "default": "./dist/seed-data/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "make": "node scripts/migrate.mjs create -j ts",
    "migrate": "node scripts/migrate.mjs up",
    "up": "node scripts/migrate.mjs up",
    "down": "node scripts/migrate.mjs down",
    "redo": "node scripts/migrate.mjs redo",
    "status": "node scripts/migrate.mjs up --dry-run",
    "seed": "node --import tsx/esm src/seed.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "node-pg-migrate": "^8.0.4",
    "pg": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  }
}
