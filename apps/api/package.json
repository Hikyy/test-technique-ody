{
  "name": "@ody/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx scripts/seed.ts",
    "seed:chef": "tsx scripts/ensure-chef.ts",
    "mail:test": "tsx scripts/test-mail.ts",
    "lint": "biome check src && eslint src",
    "lint:check": "biome check src && eslint src",
    "lint:fix": "eslint src --fix && biome check src --write",
    "format": "eslint src --fix && biome check src --write",
    "format:check": "biome check src && eslint src"
  },
  "dependencies": {
    "@better-auth/expo": "^1.6.9",
    "@hono/node-server": "^2.0.2",
    "@hono/zod-validator": "^0.4.3",
    "@ody/db": "workspace:*",
    "@ody/domain": "workspace:*",
    "@scalar/hono-api-reference": "^0.10.14",
    "better-auth": "^1.6.9",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "hono-openapi": "^0.4.8",
    "nodemailer": "^8.0.7",
    "openapi-types": "^12.1.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "catalog:",
    "zod-openapi": "^4.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/nodemailer": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "catalog:"
  }
}
