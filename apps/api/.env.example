# ============================================================================
# Sève API — environment variables (Hono + better-auth + Drizzle)
# ============================================================================
# Copy to apps/api/.env and adjust per environment.
# Schema source of truth: apps/api/src/config.ts (Zod).

# --- Runtime ---
NODE_ENV=development
API_PORT=3001

# --- Postgres ---
PG_HOST=localhost
PG_PORT=5435
PG_USER=ody
PG_PASS=ody
PG_DB=ody
# Optional: overrides PG_* if set
# DATABASE_URL=postgres://ody:ody@localhost:5435/ody

# --- Auth (better-auth) ---
# Generate with: openssl rand -base64 32  (min 16 chars)
AUTH_SECRET=replace-me-with-a-long-random-string
AUTH_URL=http://localhost:3001

# --- CORS ---
# Comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:3000

# --- Logging ---
LOG_LEVEL=info

# --- Storage (file uploads) ---
STORAGE_DIR=storage
STORAGE_PUBLIC_PATH=/storage
UPLOAD_MAX_BYTES=2097152

# --- Mail (Mailpit in dev: localhost:1025 / UI on :8025) ---
MAIL_HOST=localhost
MAIL_PORT=1025
# MAIL_USER=
# MAIL_PASS=
MAIL_FROM=Sève <noreply@seve.local>
MAIL_SECURE=false

# --- Web app URL (used in invitation links) ---
WEB_URL=http://localhost:3000
